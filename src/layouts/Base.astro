---
import '../styles/global.css';
import Logo from '../components/Logo.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import { SITE_NAME, OG_IMAGE, LEGAL_EMAIL } from '../lib/site';

interface Props {
  title: string;
  description: string;
  /** Path of this page (e.g. "/pricing"). Used for the canonical URL. */
  path: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  path,
  ogImage = OG_IMAGE,
  ogType = 'website',
  jsonLd = [],
} = Astro.props;

const canonical = new URL(path, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

// Primary header nav. Active state is derived from `path`: Home matches only
// the root; the others match their section (so /forms/{slug} keeps Forms lit).
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/forms/', label: 'Forms' },
  { href: '/pricing', label: 'Pricing' },
];
function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  const base = href.replace(/\/$/, '');
  return path === base || path.startsWith(`${base}/`);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />

    <!-- Self-hosted display + body fonts (no CDN) -->
    <link rel="preload" href="/fonts/archivo-black-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!--
      GoatCounter analytics — activate after account creation.
      The CSP in vercel.json already allows gc.zgo.at + the goatcounter origin.
    -->
    <!-- GoatCounter analytics — activate after account creation
    <script data-goatcounter="https://qualireps.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
    -->

    {
      jsonLd.map((obj) => (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(obj)} />
      ))
    }
  </head>
  <body>
    <header class="site-header" id="siteHeader">
      <div class="wrap header-inner">
        <a href="/" class="logo" aria-label="QualiReps home">
          <Logo wordmark="#e8e4de" />
        </a>
        <nav class="site-nav" aria-label="Primary">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="header-right">
          <LangSwitcher />
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer>
      <div class="wrap foot-inner">
        <div class="foot-logo">
          <Logo wordmark="#a59f97" />
          <span class="foot-meta">A daily strength practice tool · v1.0</span>
        </div>
        <nav aria-label="Footer">
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/forms">Forms</a>
          <a href={`mailto:${LEGAL_EMAIL}`}>Contact</a>
        </nav>
      </div>
      <div class="wrap">
        <div class="built">
          <span>© 2026 Olivier Lamglait · {SITE_NAME} · Made in France</span>
          <span>No trackers · No ads · No subscription</span>
        </div>
      </div>
    </footer>

    <script>
      // Sticky-header hairline on scroll (progressive enhancement).
      const header = document.getElementById('siteHeader');
      if (header) {
        const onScroll = () =>
          header.classList.toggle('scrolled', window.scrollY > 8);
        document.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        // Reveal-on-scroll.
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 }
        );
        document
          .querySelectorAll('section, .reveal-item')
          .forEach((el) => {
            el.classList.add('reveal');
            io.observe(el);
          });
      }
    </script>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(28, 26, 24, 0.85);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid transparent;
        transition: border-color 0.25s ease, background 0.25s ease;
      }
      .site-header.scrolled {
        border-bottom-color: var(--hairline-soft);
        background: rgba(20, 18, 16, 0.92);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 100px;
        gap: 16px;
      }
      .logo {
        display: flex;
        align-items: center;
        height: 72px;
      }
      .logo :global(svg) {
        height: 72px;
        width: auto;
        display: block;
      }
      .header-right {
        display: flex;
        align-items: center;
        gap: 22px;
      }
      .open-app {
        color: var(--fg-mute);
        font-size: 13px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .open-app:hover {
        color: var(--fg);
      }
      .open-app .arrow {
        transition: transform 0.2s ease;
      }
      .open-app:hover .arrow {
        transform: translateX(3px);
      }

      /* Primary header nav — small, muted, copper on hover, full opacity
         when active. No underline. */
      .site-nav {
        display: flex;
        align-items: center;
        gap: 28px;
      }
      .site-nav a {
        color: var(--fg-mute);
        font-size: 14px;
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .site-nav a:hover {
        color: var(--accent-hi);
      }
      .site-nav a[aria-current='page'] {
        color: var(--fg);
      }

      @media (max-width: 640px) {
        .open-app {
          display: none;
        }
        /* Nav collapses on small screens (the footer carries the links). */
        .site-nav {
          display: none;
        }
        .header-inner {
          height: 68px;
        }
        .logo,
        .logo :global(svg) {
          height: 42px;
        }
      }

      #main {
        position: relative;
        z-index: 1;
      }

      footer {
        background: #0f0d0c;
        border-top: 1px solid #2a2624;
        padding: 48px 0 40px;
        color: var(--fg-mute);
      }
      .foot-inner {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 32px;
        flex-wrap: wrap;
      }
      .foot-logo {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .foot-logo :global(svg) {
        height: 44px;
        width: auto;
      }
      .foot-meta {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.04em;
        color: var(--fg-dim);
      }
      footer nav {
        display: flex;
        gap: 28px;
        flex-wrap: wrap;
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.04em;
      }
      footer nav a {
        color: var(--fg-mute);
      }
      footer nav a:hover {
        color: var(--accent-hi);
      }
      .built {
        margin-top: 36px;
        padding-top: 24px;
        border-top: 1px solid #1f1c1a;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.06em;
        color: var(--fg-dim);
        text-transform: uppercase;
      }
    </style>
  </body>
</html>
