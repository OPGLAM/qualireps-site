---
import Base from '../layouts/Base.astro';
import { APP_URL, APP_HOST } from '../lib/site';

// Prerendered shell. The transaction id arrives in the URL (Paddle appends
// `_ptxn` on the checkout success redirect); the key is fetched client-side
// from /api/license, which may lag the payment by a moment.
const title = 'Thank you — QualiReps';
const description = 'Your QualiReps purchase is complete. Your license key.';
---

<Base title={title} description={description} path="/thanks">
  <div class="wrap">
    <article class="thanks">
      <div class="eyebrow">Purchase complete</div>
      <h1>Thank you.</h1>
      <p class="lead">
        Your license key is below. It has also been sent to your email.
      </p>

      <div id="state-loading" class="state">Retrieving your license key…</div>

      <div id="state-key" class="state" hidden>
        <div class="key-label">License key</div>
        <div class="key-row">
          <code id="license-key"></code>
          <button id="copy-btn" class="btn btn-ghost" type="button">Copy</button>
        </div>
        <p class="key-note">
          Open <a href={APP_URL}>{APP_HOST}</a> and enter it: Settings → License.
          One license covers Android, iOS, and desktop.
        </p>
      </div>

      <div id="state-error" class="state" hidden>
        <p>
          We couldn't retrieve your key automatically. It has been emailed to
          you. If it doesn't arrive within a few minutes, contact
          legal@qualireps.app.
        </p>
      </div>

      <p class="fine">
        Payment processed by Paddle. See the <a href="/refund">Refund Policy</a>.
      </p>
    </article>
  </div>

  <script is:inline>
    (function () {
      var params = new URLSearchParams(window.location.search);
      // Our /buy redirect uses `txn`; `_ptxn` is kept as a Paddle fallback.
      var txn = params.get('txn') || params.get('_ptxn');

      var loading = document.getElementById('state-loading');
      var keyState = document.getElementById('state-key');
      var errState = document.getElementById('state-error');
      var keyEl = document.getElementById('license-key');
      var copyBtn = document.getElementById('copy-btn');

      function show(el) {
        loading.hidden = el !== loading;
        keyState.hidden = el !== keyState;
        errState.hidden = el !== errState;
      }

      if (!txn) {
        show(errState);
        return;
      }

      var attempts = 0;
      var MAX = 6;
      function poll() {
        attempts++;
        fetch('/api/license?txn=' + encodeURIComponent(txn))
          .then(function (r) {
            return r.ok ? r.json() : Promise.reject(r.status);
          })
          .then(function (data) {
            keyEl.textContent = data.key;
            show(keyState);
          })
          .catch(function () {
            if (attempts < MAX) {
              setTimeout(poll, 1500);
            } else {
              show(errState);
            }
          });
      }
      poll();

      if (copyBtn) {
        copyBtn.addEventListener('click', function () {
          navigator.clipboard
            .writeText(keyEl.textContent || '')
            .then(function () {
              copyBtn.textContent = 'Copied';
              setTimeout(function () {
                copyBtn.textContent = 'Copy';
              }, 2000);
            });
        });
      }
    })();
  </script>
</Base>

<style>
  .thanks {
    max-width: 44rem;
    padding: clamp(32px, 5vw, 64px) 0;
  }
  .thanks .eyebrow {
    margin-bottom: 20px;
  }
  .thanks h1 {
    font-size: clamp(2rem, 5vw, 2.75rem);
    letter-spacing: -0.02em;
    margin: 0 0 18px;
    color: var(--fg);
  }
  .thanks .lead {
    font-size: clamp(16px, 1.5vw, 19px);
    line-height: 1.6;
    color: var(--fg-mute);
    margin: 0 0 28px;
  }
  .state {
    border-top: 1px solid var(--hairline-soft);
    padding-top: 24px;
  }
  #state-loading {
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
  }
  .key-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin-bottom: 10px;
  }
  .key-row {
    display: flex;
    gap: 12px;
    align-items: stretch;
    flex-wrap: wrap;
  }
  .key-row code {
    flex: 1;
    min-width: 0;
    overflow-wrap: anywhere;
    background: var(--bg-elev-1);
    border: 1px solid var(--hairline);
    border-radius: 4px;
    padding: 14px 16px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--fg);
  }
  .key-row .btn {
    height: auto;
    padding: 0 20px;
  }
  .key-note {
    margin: 16px 0 0;
    color: var(--fg-mute);
    font-size: 14.5px;
    line-height: 1.6;
  }
  .key-note a {
    color: var(--accent-hi);
  }
  #state-error p {
    color: var(--fg-mute);
    font-size: 15px;
    line-height: 1.7;
    margin: 0;
    max-width: 60ch;
  }
  .fine {
    margin: 28px 0 0;
    padding-top: 18px;
    border-top: 1px solid var(--hairline-soft);
    color: var(--fg-dim);
    font-size: 13.5px;
  }
  .fine a {
    color: var(--accent-hi);
  }
</style>
