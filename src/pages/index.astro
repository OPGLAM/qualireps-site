---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PlatformInstall from '../components/PlatformInstall.astro';
import PaddlePrice from '../components/PaddlePrice.astro';
import { groupByChain } from '../lib/content';
import { SITE_ORIGIN, APP_URL, APP_HOST } from '../lib/site';

import heroShot from '../assets/screenshots/01-dashboard.png';
import shotFresh from '../assets/screenshots/02-exercise-fresh.png';
import shotResting from '../assets/screenshots/03-exercise-resting.png';
import shotRecovery from '../assets/screenshots/04-exercise-recovery.png';
import shotTestMax from '../assets/screenshots/05-test-max.png';
import shotCustom from '../assets/screenshots/06-custom-exercise.png';
import shotChainPicker from '../assets/screenshots/07-chain-picker.png';

const entries = await getCollection('forms');
const chains = groupByChain(entries);

// Screenshots gallery — user-controlled strip, captions editable. `alt` is a
// fuller description for assistive tech; `caption` is the short visible label.
const shots = [
  { src: shotFresh, caption: 'Your daily dose', alt: 'Exercise screen, fresh — today’s dose and set logging' },
  { src: shotResting, caption: 'Rest between sets', alt: 'Exercise screen resting between sets' },
  { src: shotRecovery, caption: 'Recovery countdown', alt: 'Exercise screen showing the recovery countdown' },
  { src: shotTestMax, caption: 'Test your max', alt: 'Screen for testing your current rep maximum' },
  { src: shotChainPicker, caption: 'Choose a progression path', alt: 'Chain picker for choosing a progression path' },
  { src: shotCustom, caption: 'Or create a custom exercise', alt: 'Screen for creating a custom exercise' },
];

const title = 'QualiReps — a strength ledger for daily practice';
const description =
  "QualiReps tracks your max, computes today's dose, and signals when to progress. A Greasing the Groove ledger: distributed across the day, never to failure. Install free from your browser on Android, iOS, and desktop; 9,99 € unlocks everything — one purchase, lifetime, no subscription.";

// GtG doctrinal paragraph — verbatim from the original landing, with <em> on
// the doctrinal phrases.
const gtgParagraph =
  'Greasing the Groove is the name the strength community has given to <em>submaximal distributed training</em> — a strength training protocol that treats strength as a motor skill, not as the byproduct of repeated training to muscular failure. The principle is simple: practice the same movement many times throughout the day, with quality repetitions, well short of failure. Each rep is performed with perfect form — if your form breaks down, the rep doesn’t count. This <em>frequent practice with submaximal effort</em> lets you accumulate high daily volume without fatigue. Over weeks, your nervous system becomes more efficient at recruiting muscle fibers for that specific movement. Your maximum number of clean reps — your <em>rep maximum</em>, or <em>RM</em> — climbs steadily, without the fatigue or soreness of traditional training to failure. GTG works in cycles. Once your max on a given exercise climbs past about 15 reps, the exercise has shifted from training strength to training muscular endurance. The protocol then calls for switching to a harder variation — for example, from standard push-ups to elevated one-arm push-ups — where your max drops back into the strength zone and the cycle restarts.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'QualiReps',
    applicationCategory: 'HealthApplication',
    operatingSystem: 'Web, Android, iOS',
    offers: { '@type': 'Offer', price: '9.99', priceCurrency: 'EUR' },
    description,
    url: SITE_ORIGIN,
  },
];

const faqs = [
  {
    q: 'Can I try QualiReps before paying?',
    a: 'Yes. The free demo lets you practice one exercise at any tier you choose, with the full instrument — set logging, dose calculation, recovery windows, notifications, backup. You only pay when you want to progress to the next tier, add more exercises, or create custom exercises.',
  },
  {
    q: 'How much does QualiReps cost? Is it a subscription?',
    a: 'No. There’s nothing to subscribe to: QualiReps is a finished tool, with no database or running costs. It’s <span data-paddle-price>9,99 €</span> — one purchase, lifetime access. You unlock from inside the app: pay once through Paddle and activation is instant. A license key is also emailed to you — that key unlocks your other devices. The free demo lets you try the instrument on one exercise before you buy.',
  },
  {
    q: 'How do I install QualiReps?',
    a: `QualiReps installs from your browser on every platform. On Android: open <a href="${APP_URL}">${APP_HOST}</a> in Chrome, tap the menu, then “Install app”. On desktop (Chrome or Edge): open <a href="${APP_URL}">${APP_HOST}</a> and click the install icon in the address bar. On iPhone: open <a href="${APP_URL}">${APP_HOST}</a> in Safari, tap the Share icon, then “Add to Home Screen”. It installs like a native app and runs offline.`,
  },
  {
    q: 'Can I do Greasing the Groove on its own, or alongside other training?',
    a: 'Both. Greasing the Groove works perfectly well as a standalone strength practice — many people do only this, perhaps with some easy cardio (a light jog now and then) for general health. It also integrates as a complement to other training, whether intense or not — strength work, sport, climbing. The single rule that governs compatibility is freshness: GtG sets must stay clean and well short of fatigue. As long as your other activity doesn’t leave you too fatigued to perform fresh, quality reps, the two coexist. If you find your GtG sets degrading, reduce volume or spacing until freshness returns. QualiReps helps here — it tracks your recovery windows so you can see when you’re fit to practice.',
  },
  {
    q: 'Does it work offline?',
    a: 'Yes — entirely. Once installed, QualiReps does not require an internet connection. A service worker caches the app shell, and all your data is stored locally on your device. Sync is optional and opt-in.',
  },
  {
    q: 'How is QualiReps distributed?',
    a: `QualiReps is a web app installed from <a href="${APP_URL}">${APP_HOST}</a> — the same app on Android, iOS, and desktop. There is no app store; you install it straight from the browser, and it runs offline once installed.`,
  },
  {
    q: 'What’s your refund policy?',
    a: 'A 14-day refund window, no questions asked, plus the EU/EEA statutory right of withdrawal. Refunds go through Paddle (the receipt email) or legal@qualireps.app. See the full <a href="/refund">refund policy</a>.',
  },
  {
    q: 'What about data privacy?',
    a: 'Your practice data lives on your device. QualiReps does not collect, transmit, or store personal data on remote servers, and there are no third-party analytics that identify you. See the full <a href="/privacy">privacy policy</a> for details.',
  },
  {
    q: 'How is my purchase tied across devices?',
    a: 'One license, every platform. When you unlock from inside the app, that device activates instantly. For your other devices — Android, iOS, desktop — enter the license key we email you. There’s no account: if you reinstall, re-enter the key. Keep it safe — it’s also shown on the success page if you buy on the web. If you lose it, contact legal@qualireps.app.',
  },
  {
    q: 'Who builds QualiReps?',
    a: 'QualiReps is built by a single independent developer.',
  },
];
---

<Base title={title} description={description} path="/" jsonLd={jsonLd}>
  <!-- ───────────── HERO ───────────── -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-grid">
        <div class="hero-copy">
          <div class="eyebrow hero-eyebrow">A daily strength practice tool · v1.0</div>
          <h1>A strength ledger for daily practice.</h1>
          <p class="hero-sub">
            QualiReps tracks your max, computes today's dose, and signals when to
            progress. Built for practitioners who train strength the patient way —
            distributed across the day, never to failure.
          </p>
          <div class="hero-cta-row">
            <a href="#install" class="btn btn-primary">Install QualiReps — free</a>
            <a href="#what-is-gtg" class="btn btn-ghost">What is GTG?</a>
          </div>
          <a href="/pricing" class="hero-price">
            <span class="lead-in">Unlock everything —</span>
            <span class="amount" data-paddle-price>9,99 €</span>
            <span class="terms">· one purchase, no subscription</span>
          </a>

          <div class="hero-meta">
            <div class="item">
              <span class="k">Protocol</span>
              <span class="v">Submaximal Distributed Training</span>
            </div>
            <div class="item">
              <span class="k">Platform</span>
              <span class="v">Web app · Android, iOS, desktop</span>
            </div>
            <div class="item">
              <span class="k">Pricing</span>
              <span class="v"><span data-paddle-price>9,99 €</span> — one-time, lifetime</span>
            </div>
          </div>
        </div>

        <div class="phone-stage">
          <div class="phone">
            <div class="phone-screen">
              <Image
                class="phone-shot"
                src={heroShot}
                alt="QualiReps dashboard showing several exercises with their state and max"
                widths={[320, 480, 640]}
                sizes="(max-width: 880px) 280px, 320px"
                format="webp"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────── 01 · WHAT IS GTG ───────────── -->
  <section id="what-is-gtg" class="section-divider">
    <div class="wrap">
      <div class="two-col">
        <div class="col-head">
          <div class="eyebrow" style="margin-bottom:24px">01 / The protocol</div>
          <h2>Greasing the Groove.</h2>
          <p class="lead" style="margin-top:18px">
            A method of building strength by treating it as a skill — practiced
            frequently, never to exhaustion.
          </p>
        </div>
        <div class="body">
          <p set:html={gtgParagraph}></p>
          <p class="muted">
            It's a distributed practice — a few short sets spread across the day,
            never to failure.
          </p>
          <div class="gtg-principles">
            <div class="p"><span class="n">01</span><div><span class="t">Daily, submaximal</span><span class="d">Well under your max, most days.</span></div></div>
            <div class="p"><span class="n">02</span><div><span class="t">Spaced sets</span><span class="d">At least 15 minutes between sets, so each one stays fresh.</span></div></div>
            <div class="p"><span class="n">03</span><div><span class="t">Never to failure</span><span class="d">Stop while your reps are still clean.</span></div></div>
            <div class="p"><span class="n">04</span><div><span class="t">Perfect form</span><span class="d">Each rep is a rehearsal — done with full form, or it doesn't count.</span></div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────── 02 · WHO IS IT FOR ───────────── -->
  <section class="for-who">
    <div class="wrap inner">
      <div>
        <div class="eyebrow" style="margin-bottom:24px">02 / Who is it for</div>
        <h2>For practitioners and athletes.</h2>
      </div>
      <div>
        <p>
          If you already know Greasing the Groove, this is the ledger for it.
          It's an instrument, not a sports coach or a medical protocol — it counts
          your sets, computes your daily dose, and tracks your recovery windows.
        </p>
        <p>
          If you train strength alongside your main practice — sport, climbing,
          grappling, or any discipline that benefits from a regular strength base —
          QualiReps gives you the protocol and the ledger: patient, progressive,
          distributed across the day, handling the dose and tracking your
          progression.
        </p>
      </div>
    </div>
  </section>

  <!-- ───────────── 03 · THE FREE DEMO ───────────── -->
  <section id="demo" class="section-divider">
    <div class="wrap">
      <div class="features-head">
        <div>
          <div class="eyebrow" style="margin-bottom:24px">03 / The free demo</div>
          <h2>Try the instrument.</h2>
        </div>
        <p class="lead">
          The free demo is the instrument trial, not a stripped-down product.
        </p>
      </div>

      <div class="demo-body">
        <p>
          You pick one exercise at any tier. You log your sets, get your daily dose,
          receive recovery windows, see your practice tracked. The full instrument
          runs on that exercise.
        </p>
        <p>
          What the demo doesn't do: progression to the next tier, creating new
          exercises, custom exercises. The criterion fires when you reach it — but
          the move to the next tier is paid.
        </p>
      </div>

      <div class="cols">
        <div class="panel">
          <h3>What you get free</h3>
          <ul>
            <li>One exercise, frozen at your chosen tier</li>
            <li>Full set logging, dose calculation, recovery windows</li>
            <li>Notifications, backup, export — the complete instrument</li>
            <li>All perfect form guides accessible</li>
          </ul>
        </div>
        <div class="panel">
          <h3>What unlocks with the full version</h3>
          <ul>
            <li>Progression to the next tier when you're ready</li>
            <li>Additional exercises across all four chains</li>
            <li>Custom exercises beyond the chains</li>
            <li>Your demo exercise and history carry over when you upgrade</li>
          </ul>
        </div>
      </div>

      <p class="lockup">One purchase, lifetime access. No subscription.</p>
    </div>
  </section>

  <!-- ───────────── 04 · SCREENSHOTS ───────────── -->
  <section id="screenshots" class="section-divider">
    <div class="wrap">
      <div class="features-head">
        <div>
          <div class="eyebrow" style="margin-bottom:24px">04 / Screenshots</div>
          <h2>See it.</h2>
        </div>
        <p class="lead">
          The instrument in practice — your dose, your rests, your recovery
          windows, your progressions.
        </p>
      </div>

      <ul class="shots" role="list">
        {
          shots.map((shot) => (
            <li class="shot">
              <div class="shot-frame">
                <Image
                  class="shot-img"
                  src={shot.src}
                  alt={shot.alt}
                  widths={[240, 360, 480]}
                  sizes="(max-width: 760px) 60vw, 220px"
                  format="webp"
                  loading="lazy"
                />
              </div>
              <span class="shot-cap">{shot.caption}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ───────────── 05 · GET QUALIREPS ───────────── -->
  <section id="install" class="section-divider">
    <div class="wrap">
      <div class="features-head">
        <div>
          <div class="eyebrow" style="margin-bottom:24px">05 / Get QualiReps</div>
          <h2>Install.</h2>
        </div>
        <p class="lead">
          Install free from your browser. Android, desktop, and iOS run the same
          web app — installed in a few taps, fully offline.
        </p>
      </div>
      <PlatformInstall />
    </div>
  </section>

  <!-- ───────────── 06 · PERFECT FORM GUIDES ───────────── -->
  <section id="forms" class="section-divider">
    <div class="wrap">
      <div class="features-head">
        <div>
          <div class="eyebrow" style="margin-bottom:24px">06 / Perfect form guides</div>
          <h2>Open knowledge.</h2>
        </div>
        <p class="lead">
          Each exercise in the QualiReps chains carries a perfect form guide — a
          checklist of the crucial points: the movement, the setup, the
          sensations, the common errors. It works alongside a demonstration
          video. They are freely accessible. The knowledge is open. The
          instrument is paid.
        </p>
      </div>

      <div class="chain-grid">
        {
          chains.map((chain) => (
            <a class="chain-card" href="/forms">
              <span class="chain-card__name">{chain.name}</span>
              <span class="chain-card__count">
                {chain.fiches.length}
                {chain.fiches.length > 1 ? ' guides' : ' guide'}
              </span>
            </a>
          ))
        }
      </div>
      <p class="forms-link">
        <a href="/forms" class="btn btn-ghost">Browse all form guides →</a>
      </p>
    </div>
  </section>

  <!-- ───────────── 07 · FAQ ───────────── -->
  <section id="faq" class="section-divider">
    <div class="wrap">
      <div class="features-head faq-head">
        <div>
          <div class="eyebrow" style="margin-bottom:24px">07 / Frequently asked</div>
          <h2>Questions.</h2>
        </div>
      </div>
      <div class="faq">
        {
          faqs.map((item) => (
            <details>
              <summary>{item.q}</summary>
              <div class="answer" set:html={item.a} />
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <PaddlePrice />
</Base>

<style>
  /* ───── HERO ───── */
  .hero {
    padding: clamp(48px, 7vw, 96px) 0 clamp(64px, 8vw, 110px);
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(40px, 6vw, 72px);
    align-items: center;
  }
  .hero-eyebrow {
    margin-bottom: 28px;
  }
  .hero h1 {
    margin-bottom: 26px;
    max-width: 14ch;
  }
  .hero-sub {
    font-size: clamp(16px, 1.45vw, 19px);
    color: var(--fg-mute);
    max-width: 52ch;
    line-height: 1.6;
    margin-bottom: 36px;
  }
  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-bottom: 22px;
  }
  .hero-price {
    display: inline-flex;
    align-items: baseline;
    flex-wrap: wrap;
    column-gap: 12px;
    row-gap: 2px;
    text-decoration: none;
  }
  .hero-price .lead-in {
    font-size: 15px;
    color: var(--fg);
  }
  .hero-price .amount {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 34px);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--accent);
    transition: color 0.15s ease;
  }
  .hero-price:hover .amount {
    color: var(--accent-hi);
  }
  .hero-price .terms {
    font-size: 13px;
    color: var(--fg-mute);
  }
  .hero-meta {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--hairline-soft);
    display: flex;
    flex-wrap: wrap;
    gap: clamp(20px, 3vw, 44px);
  }
  .hero-meta .item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero-meta .k {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .hero-meta .v {
    font-size: 14px;
    color: var(--fg);
  }

  .phone-stage {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }
  .phone-stage::before {
    content: '';
    position: absolute;
    inset: 10% -10% 10% -10%;
    background: radial-gradient(
      closest-side,
      rgba(217, 144, 74, 0.1),
      transparent 70%
    );
    filter: blur(20px);
    z-index: 0;
    pointer-events: none;
  }
  .phone {
    position: relative;
    z-index: 1;
    width: min(320px, 100%);
    aspect-ratio: 430 / 932;
    background: #0e0c0b;
    border-radius: 44px;
    padding: 12px;
    box-shadow: 0 0 0 1px #2a2622 inset, 0 30px 60px -20px rgba(0, 0, 0, 0.7),
      0 10px 30px -10px rgba(0, 0, 0, 0.5);
    border: 1px solid #2a2622;
  }
  .phone-screen {
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, #1c1a18 0%, #161412 100%);
    border-radius: 32px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .phone-shot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Anchor to the top so the dark top margin (corner clearance) is what
       the rounded frame clips — never the app's top-corner icons. The
       bottom of the screenshot overflows and is clipped instead. */
    object-position: top;
    display: block;
    border-radius: 32px;
  }
  @media (max-width: 880px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  /* ───── TWO-COL (GtG) ───── */
  .two-col {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
    gap: clamp(32px, 6vw, 88px);
    align-items: start;
  }
  .two-col .col-head h2 {
    margin-bottom: 16px;
  }
  .two-col .body p {
    color: var(--fg);
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 18px;
  }
  .two-col .body p :global(em) {
    color: var(--accent-hi);
    font-style: italic;
  }
  .two-col .body p.muted {
    color: var(--fg-mute);
    font-size: 15px;
    font-style: italic;
  }
  .gtg-principles {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--hairline-soft);
  }
  .gtg-principles .p {
    padding: 18px 0;
    border-bottom: 1px solid var(--hairline-soft);
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .gtg-principles .p:nth-child(odd) {
    padding-right: 24px;
    border-right: 1px solid var(--hairline-soft);
  }
  .gtg-principles .p:nth-child(even) {
    padding-left: 24px;
  }
  .gtg-principles .n {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--accent);
    font-weight: 600;
    padding-top: 3px;
    min-width: 22px;
  }
  .gtg-principles .t {
    font-weight: 600;
    font-size: 15px;
    color: var(--fg);
    display: block;
    margin-bottom: 4px;
  }
  .gtg-principles .d {
    color: var(--fg-mute);
    font-size: 14px;
    line-height: 1.55;
  }
  @media (max-width: 760px) {
    .two-col {
      grid-template-columns: 1fr;
    }
    .gtg-principles {
      grid-template-columns: 1fr;
    }
    .gtg-principles .p:nth-child(odd) {
      padding-right: 0;
      border-right: 0;
    }
    .gtg-principles .p:nth-child(even) {
      padding-left: 0;
    }
  }

  /* ───── WHO (for-who) ───── */
  .for-who {
    background: var(--bg-deep);
    border-top: 1px solid var(--hairline-soft);
    border-bottom: 1px solid var(--hairline-soft);
  }
  .for-who .inner {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: clamp(28px, 5vw, 72px);
    align-items: start;
  }
  .for-who p {
    font-size: clamp(18px, 1.7vw, 22px);
    line-height: 1.55;
    color: var(--fg);
  }
  .for-who p + p {
    margin-top: 18px;
    color: var(--fg-mute);
    font-size: clamp(16px, 1.4vw, 18px);
  }
  @media (max-width: 760px) {
    .for-who .inner {
      grid-template-columns: 1fr;
    }
  }

  /* ───── shared section head ───── */
  .features-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 32px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .features-head h2 {
    max-width: 16ch;
  }
  .features-head .lead {
    max-width: 38ch;
  }

  /* ───── DEMO ───── */
  .demo-body {
    max-width: 65ch;
    margin-bottom: 32px;
  }
  .demo-body p {
    color: var(--fg);
    font-size: 17px;
    line-height: 1.7;
  }
  .demo-body p + p {
    margin-top: 16px;
    color: var(--fg-mute);
  }
  .cols {
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(2, 1fr);
    background: var(--hairline-soft);
    border: 1px solid var(--hairline-soft);
    border-radius: 6px;
    overflow: hidden;
  }
  .panel {
    background: var(--bg);
