---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PlatformInstall from '../components/PlatformInstall.astro';
import { groupByChain } from '../lib/content';
import { PLAY_STORE_URL } from '../lib/playBilling';
import { SITE_ORIGIN } from '../lib/site';

const entries = await getCollection('forms');
const chains = groupByChain(entries);

const title = 'QualiReps — a strength ledger for daily practice';
const description =
  "QualiReps tracks your max, computes today's dose, and signals when to progress. A Greasing the Groove ledger: distributed across the day, never to failure, for years. 9,99 € on Google Play — one purchase, lifetime access.";

// GtG doctrinal paragraph — verbatim from the original landing, with <em> on
// the doctrinal phrases.
const gtgParagraph =
  'Greasing the Groove is the name the strength community has given to <em>submaximal distributed training</em> — a strength training protocol that treats strength as a motor skill, not as the byproduct of repeated training to muscular failure. The principle is simple: practice the same movement many times throughout the day, with quality repetitions, well short of failure. Each rep is performed with perfect form — if your form breaks down, the rep doesn’t count. This <em>frequent practice with submaximal effort</em> lets you accumulate high daily volume without fatigue. Over weeks, your nervous system becomes more efficient at recruiting muscle fibers for that specific movement. Your maximum number of clean reps — your <em>rep maximum</em>, or <em>RM</em> — climbs steadily, without the fatigue or soreness of traditional training to failure. GTG works in cycles. Once your max on a given exercise climbs past about 15 reps, the exercise has shifted from training strength to training muscular endurance. The protocol then calls for switching to a harder variation — for example, from standard push-ups to elevated one-arm push-ups — where your max drops back into the strength zone and the cycle restarts.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'QualiReps',
    applicationCategory: 'HealthApplication',
    operatingSystem: 'Android, Web',
    offers: { '@type': 'Offer', price: '9.99', priceCurrency: 'EUR' },
    description,
    url: SITE_ORIGIN,
  },
];

const faqs = [
  {
    q: 'Can I try QualiReps before paying?',
    a: 'Yes. The free demo lets you practice one exercise at any tier you choose, with the full instrument — set logging, dose calculation, recovery windows, notifications, backup. You only pay when you want to progress to the next tier, add more exercises, or create custom exercises.',
  },
  {
    q: 'How much does QualiReps cost? Is it a subscription?',
    a: 'QualiReps is 9,99 € on Google Play. One purchase, lifetime access. No subscription, no yearly fee, no recurring billing, and no premium tier that comes later. The free demo lets you try the instrument on one exercise before you buy.',
  },
  {
    q: 'How do I install QualiReps?',
    a: 'On Android: get QualiReps from Google Play — that’s the full app. On desktop (Chrome or Edge): open qualireps.app and click the install icon in the address bar. On iPhone: open qualireps.app in Safari, tap the Share icon, then “Add to Home Screen”. Desktop and iOS run as a free demo; native versions are in development.',
  },
  {
    q: 'Can I do Greasing the Groove on its own, or alongside other training?',
    a: 'Both. Greasing the Groove works perfectly well as a standalone strength practice — many people do only this, perhaps with some easy cardio (a light jog now and then) for general health. It also integrates as a complement to other training, whether intense or not — strength work, sport, climbing, martial arts. The single rule that governs compatibility is freshness: GtG sets must stay clean and well short of fatigue. As long as your other activity doesn’t leave you too fatigued to perform fresh, quality reps, the two coexist. If you find your GtG sets degrading, reduce volume or spacing until freshness returns. QualiReps helps here — it tracks your recovery windows so you can see when you’re fit to practice.',
  },
  {
    q: 'Does it work offline?',
    a: 'Yes — entirely. Once installed, QualiReps does not require an internet connection. A service worker caches the app shell, and all your data is stored locally on your device. Sync is optional and opt-in.',
  },
  {
    q: 'How is QualiReps distributed?',
    a: 'The full app is on Google Play for Android. On desktop and iOS, QualiReps runs as an installable web app from qualireps.app — a free demo for now, with native versions in development.',
  },
  {
    q: 'What’s your refund policy?',
    a: 'Refunds are handled by Google Play. You can request a refund within 48 hours of purchase directly through your Google account.',
  },
  {
    q: 'What about data privacy?',
    a: 'Your practice data lives on your device. QualiReps does not collect, transmit, or store personal data on remote servers, and there are no third-party analytics that identify you. See the full <a href="/privacy">privacy policy</a> for details.',
  },
  {
    q: 'How is my purchase tied across devices?',
    a: 'Your purchase is tied to your Google account. If you uninstall and reinstall, it is restored automatically when you use the same account — no key to paste, no login loops. If it isn’t restored, contact legal@qualireps.app.',
  },
  {
    q: 'Who builds QualiReps?',
    a: 'QualiReps is built by a single independent developer. It’s not a venture-backed startup or a growth team. Just one person who cares about doing this right.',
  },
];
---

<Base title={title} description={description} path="/" jsonLd={jsonLd}>
  <!-- ───────────── HERO ───────────── -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-grid">
        <div class="hero-copy">
          <div class="eyebrow hero-eyebrow">A daily strength practice tool · v1.0</div>
          <h1>A strength ledger for daily practice.</h1>
          <p class="hero-sub">
            QualiReps tracks your max, computes today's dose, and signals when to
            progress. Built for practitioners who train strength the patient way —
            distributed across the day, never to failure, for years.
          </p>
          <div class="hero-cta-row">
            <a href={PLAY_STORE_URL} rel="noopener" class="btn btn-primary">
              Get it on Google Play — full version
            </a>
            <a href="#what-is-gtg" class="btn btn-ghost">What is GTG?</a>
          </div>
          <p class="reassure">
            9,99 € launch price. One purchase, lifetime access. No subscription.
          </p>

          <div class="hero-meta">
            <div class="item">
              <span class="k">Protocol</span>
              <span class="v">Submaximal Distributed Training</span>
            </div>
            <div class="item">
              <span class="k">Platform</span>
              <span class="v">Google Play (full) · Desktop and iOS (free demo)</span>
            </div>
            <div class="item">
              <span class="k">Pricing</span>
              <span class="v">9,99 € — launch price</span>
            </div>
          </div>
        </div>

        <div class="phone-stage" aria-hidden="true">
          <div class="phone phone-placeholder">
            <div class="phone-screen">
              <span class="placeholder-label">App screenshot</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────── 01 · WHAT IS GTG ───────────── -->
  <section id="what-is-gtg" class="section-divider">
    <div class="wrap">
      <div class="two-col">
        <div class="col-head">
          <div class="eyebrow" style="margin-bottom:24px">01 / The protocol</div>
          <h2>Greasing the Groove.</h2>
          <p class="lead" style="margin-top:18px">
            A method of building strength by treating it as a skill — practiced
            frequently, never to exhaustion.
          </p>
        </div>
        <div class="body">
          <p set:html={gtgParagraph}></p>
          <p class="muted">
            It is a disciplined, distributed practice. Two sets in the morning, one
            before lunch, one at five, one before bed. Quality over quantity.
            Movement over numbers. Never to failure.
          </p>
          <div class="gtg-principles">
            <div class="p"><span class="n">01</span><div><span class="t">Daily, submaximal</span><span class="d">30–50% of your daily max, every single day.</span></div></div>
            <div class="p"><span class="n">02</span><div><span class="t">Spaced sets</span><span class="d">15 minutes minimum between sets. Stay fresh.</span></div></div>
            <div class="p"><span class="n">03</span><div><span class="t">Never to failure</span><span class="d">Stop two reps before the wall. Always.</span></div></div>
            <div class="p"><span class="n">04</span><div><span class="t">Perfect form</span><span class="d">Each rep is a rehearsal. Sloppy reps wire sloppy patterns.</span></div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────── 02 · WHO IS IT FOR ───────────── -->
  <section class="for-who">
    <div class="wrap inner">
      <div>
        <div class="eyebrow" style="margin-bottom:24px">02 / Who is it for</div>
        <h2>For practitioners and athletes.</h2>
      </div>
      <div>
        <p>
          If you already know Greasing the Groove, QualiReps is the ledger you've
          been missing. It counts your sets, calculates your daily dose, tracks
          your recovery windows, and stays out of your way. No notebook, no
          spreadsheet, no friction.
        </p>
        <p>
          If you train strength alongside your main practice — sport, climbing,
          grappling, or any discipline that benefits from a regular strength base —
          QualiReps gives you the protocol and the ledger. Patient, progressive,
          distributed across the day. No coaching, no programs, no nags — just the
          tool that handles the dose and tracks your progression.
        </p>
      </div>
    </div>
  </section>

  <!-- ───────────── 03 · THE FREE DEMO ───────────── -->
  <section id="demo" class="section-divider">
    <div class="wrap">
      <div class="features-head">
        <div>
          <div class="eyebrow" style="margin-bottom:24px">03 / The free demo</div>
          <h2>Try the instrument.</h2>
        </div>
        <p class="lead">
          The free demo is the instrument trial, not a stripped-down product.
        </p>
      </div>

      <div class="demo-body">
        <p>
          You pick one exercise at any tier. You log your sets, get your daily dose,
          receive recovery windows, see your practice tracked. The full instrument
          runs on that exercise.
        </p>
        <p>
          What the demo doesn't do: progression to the next tier, creating new
          exercises, custom exercises. The criterion fires when you reach it — but
          the move to the next tier is paid.
        </p>
      </div>

      <div class="cols">
        <div class="panel">
          <h3>What you get free</h3>
          <ul>
            <li>One exercise, frozen at your chosen tier</li>
            <li>Full set logging, dose calculation, recovery windows</li>
            <li>Notifications, backup, export — the complete instrument</li>
            <li>All perfect form guides accessible</li>
          </ul>
        </div>
        <div class="panel">
          <h3>What unlocks with the full version</h3>
          <ul>
            <li>Progression to the next tier when you're ready</li>
            <li>Additional exercises across all four chains</li>
            <li>Custom exercises beyond the chains</li>
            <li>Your demo exercise and history carry over when you upgrade</li>
          </ul>
        </div>
      </div>

      <p class="lockup">One purchase, lifetime access. No subscription.</p>
    </div>
  </section>

  <!-- ───────────── 04 · GET QUALIREPS ───────────── -->
  <section id="install" class="section-divider">
    <div class="wrap">
      <div class="features-head">
        <div>
          <div class="eyebrow" style="margin-bottom:24px">04 / Get QualiReps</div>
          <h2>Install.</h2>
        </div>
        <p class="lead">
          Android runs the full app from Google Play. Desktop and iOS run a free
          demo today, with native versions in development.
        </p>
      </div>
      <PlatformInstall />
    </div>
  </section>

  <!-- ───────────── 05 · PERFECT FORM GUIDES ───────────── -->
  <section id="forms" class="section-divider">
    <div class="wrap">
      <div class="features-head">
        <div>
          <div class="eyebrow" style="margin-bottom:24px">05 / Perfect form guides</div>
          <h2>Open knowledge.</h2>
        </div>
        <p class="lead">
          Each exercise in the QualiReps chains carries a perfect form guide — the
          movement, the setup, the sensations, the common errors. They are freely
          accessible. The knowledge is open. The instrument is paid.
        </p>
      </div>

      <div class="chain-grid">
        {
          chains.map((chain) => (
            <a class="chain-card" href="/forms">
              <span class="chain-card__name">{chain.name}</span>
              <span class="chain-card__count">
                {chain.fiches.length}
                {chain.fiches.length > 1 ? ' guides' : ' guide'}
              </span>
            </a>
          ))
        }
      </div>
      <p class="forms-link">
        <a href="/forms" class="btn btn-ghost">Browse all form guides →</a>
      </p>
    </div>
  </section>

  <!-- ───────────── 06 · FAQ ───────────── -->
  <section id="faq" class="section-divider">
    <div class="wrap">
      <div class="features-head faq-head">
        <div>
          <div class="eyebrow" style="margin-bottom:24px">06 / Frequently asked</div>
          <h2>Questions.</h2>
        </div>
      </div>
      <div class="faq">
        {
          faqs.map((item) => (
            <details>
              <summary>{item.q}</summary>
              <div class="answer" set:html={item.a} />
            </details>
          ))
        }
      </div>
    </div>
  </section>
</Base>

<style>
  /* ───── HERO ───── */
  .hero {
    padding: clamp(48px, 7vw, 96px) 0 clamp(64px, 8vw, 110px);
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(40px, 6vw, 72px);
    align-items: center;
  }
  .hero-eyebrow {
    margin-bottom: 28px;
  }
  .hero h1 {
    margin-bottom: 26px;
    max-width: 14ch;
  }
  .hero-sub {
    font-size: clamp(16px, 1.45vw, 19px);
    color: var(--fg-mute);
    max-width: 52ch;
    line-height: 1.6;
    margin-bottom: 36px;
  }
  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-bottom: 22px;
  }
  .hero-meta {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--hairline-soft);
    display: flex;
    flex-wrap: wrap;
    gap: clamp(20px, 3vw, 44px);
  }
  .hero-meta .item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero-meta .k {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .hero-meta .v {
    font-size: 14px;
    color: var(--fg);
  }

  .phone-stage {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }
  .phone-stage::before {
    content: '';
    position: absolute;
    inset: 10% -10% 10% -10%;
    background: radial-gradient(
      closest-side,
      rgba(217, 144, 74, 0.1),
      transparent 70%
    );
    filter: blur(20px);
    z-index: 0;
    pointer-events: none;
  }
  .phone {
    position: relative;
    z-index: 1;
    width: min(320px, 100%);
    aspect-ratio: 430 / 932;
    background: #0e0c0b;
    border-radius: 44px;
    padding: 12px;
    box-shadow: 0 0 0 1px #2a2622 inset, 0 30px 60px -20px rgba(0, 0, 0, 0.7),
      0 10px 30px -10px rgba(0, 0, 0, 0.5);
    border: 1px solid #2a2622;
  }
  .phone-screen {
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, #1c1a18 0%, #161412 100%);
    border-radius: 32px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .placeholder-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  @media (max-width: 880px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  /* ───── TWO-COL (GtG) ───── */
  .two-col {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
    gap: clamp(32px, 6vw, 88px);
    align-items: start;
  }
  .two-col .col-head h2 {
    margin-bottom: 16px;
  }
  .two-col .body p {
    color: var(--fg);
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 18px;
  }
  .two-col .body p :global(em) {
    color: var(--accent-hi);
    font-style: italic;
  }
  .two-col .body p.muted {
    color: var(--fg-mute);
    font-size: 15px;
    font-style: italic;
  }
  .gtg-principles {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--hairline-soft);
  }
  .gtg-principles .p {
    padding: 18px 0;
    border-bottom: 1px solid var(--hairline-soft);
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .gtg-principles .p:nth-child(odd) {
    padding-right: 24px;
    border-right: 1px solid var(--hairline-soft);
  }
  .gtg-principles .p:nth-child(even) {
    padding-left: 24px;
  }
  .gtg-principles .n {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--accent);
    font-weight: 600;
    padding-top: 3px;
    min-width: 22px;
  }
  .gtg-principles .t {
    font-weight: 600;
    font-size: 15px;
    color: var(--fg);
    display: block;
    margin-bottom: 4px;
  }
  .gtg-principles .d {
    color: var(--fg-mute);
    font-size: 14px;
    line-height: 1.55;
  }
  @media (max-width: 760px) {
    .two-col {
      grid-template-columns: 1fr;
    }
    .gtg-principles {
      grid-template-columns: 1fr;
    }
    .gtg-principles .p:nth-child(odd) {
      padding-right: 0;
      border-right: 0;
    }
    .gtg-principles .p:nth-child(even) {
      padding-left: 0;
    }
  }

  /* ───── WHO (for-who) ───── */
  .for-who {
    background: var(--bg-deep);
    border-top: 1px solid var(--hairline-soft);
    border-bottom: 1px solid var(--hairline-soft);
  }
  .for-who .inner {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: clamp(28px, 5vw, 72px);
    align-items: start;
  }
  .for-who p {
    font-size: clamp(18px, 1.7vw, 22px);
    line-height: 1.55;
    color: var(--fg);
  }
  .for-who p + p {
    margin-top: 18px;
    color: var(--fg-mute);
    font-size: clamp(16px, 1.4vw, 18px);
  }
  @media (max-width: 760px) {
    .for-who .inner {
      grid-template-columns: 1fr;
    }
  }

  /* ───── shared section head ───── */
  .features-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 32px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .features-head h2 {
    max-width: 16ch;
  }
  .features-head .lead {
    max-width: 38ch;
  }

  /* ───── DEMO ───── */
  .demo-body {
    max-width: 65ch;
    margin-bottom: 32px;
  }
  .demo-body p {
    color: var(--fg);
    font-size: 17px;
    line-height: 1.7;
  }
  .demo-body p + p {
    margin-top: 16px;
    color: var(--fg-mute);
  }
  .cols {
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(2, 1fr);
    background: var(--hairline-soft);
    border: 1px solid var(--hairline-soft);
    border-radius: 6px;
    overflow: hidden;
  }
  .panel {
    background: var(--bg);
    padding: clamp(24px, 2.8vw, 36px);
  }
  .panel h3 {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 16px;
  }
  .panel ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .panel li {
    position: relative;
    padding-left: 1.5rem;
    margin: 0.7rem 0;
    color: var(--fg);
    font-size: 15px;
    line-height: 1.5;
  }
  .panel li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .lockup {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 26px);
    color: var(--fg);
    margin: 32px 0 0;
    letter-spacing: -0.01em;
  }
  @media (max-width: 560px) {
    .cols {
      grid-template-columns: 1fr;
    }
  }

  /* ───── FORMS preview ───── */
  .chain-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--hairline-soft);
    border: 1px solid var(--hairline-soft);
    border-radius: 6px;
    overflow: hidden;
  }
  .chain-card {
    background: var(--bg);
    padding: clamp(20px, 2.4vw, 30px);
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: background 0.2s ease;
  }
  .chain-card:hover {
    background: var(--bg-elev-1);
    color: var(--fg);
  }
  .chain-card__name {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--fg);
    letter-spacing: -0.01em;
  }
  .chain-card__count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .forms-link {
    margin-top: 28px;
  }
  @media (max-width: 880px) {
    .chain-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .chain-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ───── FAQ ───── */
  .faq-head {
    margin-bottom: 44px;
  }
  .faq {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--hairline-soft);
  }
  .faq details {
    border-bottom: 1px solid var(--hairline-soft);
  }
  .faq summary {
    list-style: none;
    cursor: pointer;
    padding: 22px 0;
    display: grid;
    grid-template-columns: 1fr 28px;
    gap: 16px;
    align-items: center;
    font-size: clamp(16px, 1.4vw, 18px);
    font-weight: 600;
    color: var(--fg);
    transition: color 0.15s ease;
  }
  .faq summary:hover {
    color: var(--accent-hi);
  }
  .faq summary::-webkit-details-marker {
    display: none;
  }
  .faq summary::after {
    content: '+';
    font-family: var(--font-mono);
    font-size: 20px;
    color: var(--accent);
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--hairline);
    border-radius: 50%;
    transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
  }
  .faq details[open] summary::after {
    content: '–';
    background: var(--accent);
    color: #1c1a18;
