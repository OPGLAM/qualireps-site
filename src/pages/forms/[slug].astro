---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import {
  exerciseName,
  ficheDescription,
  ficheSlug,
  chainName,
  howToSteps,
  neighbors,
  type FormEntry,
} from '../../lib/content';
import { SITE_ORIGIN } from '../../lib/site';

export async function getStaticPaths() {
  const entries = await getCollection('forms');
  return entries.map((entry) => ({
    params: { slug: ficheSlug(entry) },
    props: { entry, all: entries },
  }));
}

interface Props {
  entry: FormEntry;
  all: FormEntry[];
}
const { entry, all } = Astro.props;

const { Content } = await render(entry);

const name = exerciseName(entry);
const description = ficheDescription(entry);
const slug = ficheSlug(entry);
const chain = chainName(entry.data.chain);
const { prev, next } = neighbors(entry, all);

const title = `${name} — perfect form guide | QualiReps`;
const pageUrl = `${SITE_ORIGIN}/forms/${slug}`;

const steps = howToSteps(entry);

const jsonLd: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_ORIGIN}/` },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Forms',
        item: `${SITE_ORIGIN}/forms`,
      },
      { '@type': 'ListItem', position: 3, name: chain, item: `${SITE_ORIGIN}/forms` },
      { '@type': 'ListItem', position: 4, name, item: pageUrl },
    ],
  },
];

if (steps.length > 0) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name,
    description,
    step: steps.map((text, i) => ({
      '@type': 'HowToStep',
      position: i + 1,
      text,
    })),
  });
}
---

<Base
  title={title}
  description={description}
  path={`/forms/${slug}`}
  ogType="article"
  jsonLd={jsonLd}
>
  <div class="wrap">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/forms">Forms</a>
      <span aria-hidden="true">/</span>
      <span>{chain}</span>
    </nav>

    <article class="prose fiche">
      <Content />
    </article>

    {
      (prev || next) && (
        <nav class="tier-nav" aria-label="Tier navigation">
          {prev ? (
            <a class="tier-nav__link tier-nav__prev" href={`/forms/${ficheSlug(prev)}`}>
              <span class="tier-nav__dir">← Previous tier</span>
              <span class="tier-nav__name">{exerciseName(prev)}</span>
            </a>
          ) : (
            <span />
          )}
          {next && (
            <a class="tier-nav__link tier-nav__next" href={`/forms/${ficheSlug(next)}`}>
              <span class="tier-nav__dir">Next tier →</span>
              <span class="tier-nav__name">{exerciseName(next)}</span>
            </a>
          )}
        </nav>
      )
    }

    <aside class="fiche-cta">
      <p>Get QualiReps and put this guide to work.</p>
      <a href="/#install" class="btn btn-primary">Install QualiReps — free</a>
      <p class="fiche-cta__alt">
        Installs from your browser on Android, iOS, and desktop. One exercise
        free with the full instrument; <a href="/pricing">9,99 € unlocks
        everything</a>.
      </p>
    </aside>
  </div>
</Base>

<style>
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-fg-tertiary);
    padding: 1rem 0 0.5rem;
  }
  .crumbs a {
    color: var(--color-fg-secondary);
    text-decoration: none;
  }
  .crumbs a:hover {
    color: var(--color-cuivre);
  }
  .fiche {
    padding: 0.5rem 0 1rem;
  }
  .tier-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin: 2rem 0;
    max-width: 70ch;
  }
  .tier-nav__link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.9rem 1rem;
    background: var(--color-surface-1);
    border: 1px solid var(--color-border-subtle);
    border-radius: 10px;
    text-decoration: none;
  }
  .tier-nav__link:hover {
    border-color: var(--color-cuivre);
  }
  .tier-nav__next {
    text-align: right;
  }
  .tier-nav__dir {
    font-size: 0.8rem;
    color: var(--color-cuivre);
  }
  .tier-nav__name {
    color: var(--color-fg);
    font-weight: 600;
  }
  .fiche-cta {
    margin: 2.5rem 0 1rem;
    padding: 1.5rem;
    background: var(--color-surface-1);
    border: 1px solid var(--color-border-subtle);
    border-radius: 12px;
    max-width: 70ch;
  }
  .fiche-cta > p {
    margin: 0 0 1rem;
    color: var(--color-fg);
    font-weight: 600;
  }
  .fiche-cta__alt {
    margin: 1rem 0 0 !important;
    font-weight: 400 !important;
    font-size: 0.9rem;
    color: var(--color-fg-tertiary) !important;
  }
  .fiche-cta__alt a {
    color: var(--color-cuivre);
  }
</style>
