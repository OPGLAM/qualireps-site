---
/**
 * The three install sub-blocks (Android / Desktop / iOS).
 *
 * All three render server-side so the page works with no JavaScript. A small
 * bundled client script (imports the verbatim detection from src/lib/platform)
 * then reveals just the relevant block and offers a "Show all platforms"
 * toggle. Served from 'self' (Astro bundles it) — no inline-script CSP need.
 */
import PlayBadge from './PlayBadge.astro';
import QRCode from './QRCode.astro';
import { PLAY_STORE_URL } from '../lib/playBilling';
import { APP_URL, PRICE_LABEL } from '../lib/site';
---

<div class="install" data-platform-install>
  <div class="install__toggle" hidden>
    <button type="button" data-show-all>Show all platforms</button>
  </div>

  <!-- Android -->
  <section class="install__block" data-platform="android" aria-label="Android">
    <h3>Android</h3>
    <p>Get QualiReps from Google Play. The full app, {PRICE_LABEL}.</p>
    <div class="install__badge">
      <PlayBadge />
    </div>
    <p class="install__qr-label">Scan with your phone:</p>
    <QRCode value={PLAY_STORE_URL} alt="QR code linking to QualiReps on Google Play" />
  </section>

  <!-- Desktop -->
  <section class="install__block" data-platform="desktop" aria-label="Desktop">
    <h3>Desktop</h3>
    <p>
      QualiReps runs as an installable web app on Chrome and Edge. Open
      <a href={APP_URL}>qualireps.app</a>, then click the install icon in your
      browser's address bar.
    </p>
    <p class="install__note">
      Desktop is a free demo: one exercise, no progression. A native version is
      in development.
    </p>
  </section>

  <!-- iOS -->
  <section class="install__block" data-platform="ios" aria-label="iOS">
    <h3>iOS</h3>
    <p>
      Open <a href={APP_URL}>qualireps.app</a> in Safari, tap the Share icon,
      then "Add to Home Screen".
    </p>
    <p class="install__note">
      iOS is a free demo: one exercise, no progression. A native version is in
      development.
    </p>
    <p class="install__warn">
      Note: Apple's Safari may clear app data after about 7 days of non-use.
      Back up regularly to protect your practice history.
    </p>
  </section>
</div>

<script>
  import { isAndroid, isIOSSafariPWA } from '../lib/platform';

  const root = document.querySelector<HTMLElement>('[data-platform-install]');
  if (root) {
    const detected = isAndroid()
      ? 'android'
      : isIOSSafariPWA()
        ? 'ios'
        : 'desktop';

    root.dataset.detected = detected;
    root.classList.add('is-detected');

    const toggle = root.querySelector<HTMLElement>('.install__toggle');
    toggle?.removeAttribute('hidden');

    const btn = root.querySelector<HTMLButtonElement>('[data-show-all]');
    btn?.addEventListener('click', () => {
      root.classList.add('show-all');
      toggle?.setAttribute('hidden', '');
    });
  }
</script>

<style>
  .install {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
  }
  .install__block {
    background: var(--color-surface-1);
    border: 1px solid var(--color-border-subtle);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .install__block h3 {
    margin: 0 0 0.75rem;
    font-size: 1.25rem;
    color: var(--color-fg);
  }
  .install__block p {
    margin: 0 0 0.75rem;
    color: var(--color-fg-secondary);
  }
  .install__block a {
    color: var(--color-cuivre);
    text-underline-offset: 2px;
  }
  .install__badge {
    margin: 1rem 0;
  }
  .install__qr-label {
    font-size: 0.9rem;
    color: var(--color-fg-tertiary);
  }
  .install__note {
    font-size: 0.9rem;
    color: var(--color-fg-tertiary);
  }
  .install__warn {
    font-size: 0.85rem;
    color: var(--color-ambre);
    border-left: 2px solid var(--color-ambre);
    padding-left: 0.75rem;
    margin-bottom: 0;
  }
  .install__toggle {
    grid-column: 1 / -1;
    margin-bottom: -0.5rem;
  }
  .install__toggle button {
    background: transparent;
    border: 1px solid var(--color-border-default);
    color: var(--color-fg-secondary);
    border-radius: 8px;
    padding: 0.45rem 0.9rem;
    font: inherit;
    font-size: 0.875rem;
    cursor: pointer;
  }
  .install__toggle button:hover {
    border-color: var(--color-cuivre);
    color: var(--color-fg);
  }

  /* With JS + a detected platform, show only the matching block until the
     user asks for all. Default (no JS): every block stays visible. */
  .install.is-detected:not(.show-all) .install__block {
    display: none;
  }
  .install.is-detected[data-detected='android']:not(.show-all)
    .install__block[data-platform='android'],
  .install.is-detected[data-detected='desktop']:not(.show-all)
    .install__block[data-platform='desktop'],
  .install.is-detected[data-detected='ios']:not(.show-all)
    .install__block[data-platform='ios'] {
    display: block;
  }
</style>
