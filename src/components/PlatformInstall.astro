---
/**
 * The three install sub-blocks (Android / Desktop / iOS).
 *
 * All three render server-side, but Android leads by default (the primary
 * distribution channel) and is the only block shown until the visitor opts in.
 * A small bundled client script records the detected platform (kept for
 * analytics / future logic, it no longer changes the visible block) and offers
 * a "Show all platforms" toggle.
 */
import PlayBadge from './PlayBadge.astro';
import QRCode from './QRCode.astro';
import { PLAY_STORE_URL } from '../lib/playBilling';
import { APP_URL, PRICE_LABEL } from '../lib/site';
---

<div class="install" data-platform-install>
  <div class="install__toggle" hidden>
    <button type="button" data-show-all>Show all platforms</button>
  </div>

  <!-- Android -->
  <section class="how-card" data-platform="android" aria-label="Android">
    <div class="plat"><span class="badge">Android</span><span>Google Play · full app</span></div>
    <h3>Android</h3>
    <p>Get QualiReps from Google Play. The full app, {PRICE_LABEL}.</p>
    <div class="install__badge">
      <PlayBadge />
    </div>
    <p class="qr-label">Scan with your phone:</p>
    <QRCode value={PLAY_STORE_URL} alt="QR code linking to QualiReps on Google Play" />
  </section>

  <!-- Desktop -->
  <section class="how-card" data-platform="desktop" aria-label="Desktop">
    <div class="plat"><span class="badge">Desktop</span><span>Chrome · Edge · free demo</span></div>
    <h3>Desktop</h3>
    <p>
      QualiReps runs as an installable web app on Chrome and Edge. Open
      <a href={APP_URL}>qualireps.app</a>, then click the install icon in your
      browser's address bar.
    </p>
    <p class="note">
      Desktop is a free demo: one exercise, no progression. A native version is
      in development.
    </p>
  </section>

  <!-- iOS -->
  <section class="how-card" data-platform="ios" aria-label="iOS">
    <div class="plat"><span class="badge">iOS</span><span>Safari · free demo</span></div>
    <h3>iOS</h3>
    <p>
      Open <a href={APP_URL}>qualireps.app</a> in Safari, tap the Share icon,
      then "Add to Home Screen".
    </p>
    <p class="note">
      iOS is a free demo: one exercise, no progression. A native version is in
      development.
    </p>
    <p class="warn">
      Note: Apple's Safari may clear app data after about 7 days of non-use. Back
      up regularly to protect your practice history.
    </p>
  </section>
</div>

<script>
  import { isAndroid, isIOSSafariPWA } from '../lib/platform';

  const root = document.querySelector<HTMLElement>('[data-platform-install]');
  if (root) {
    // Detection is still recorded (useful for analytics / future logic) but it
    // no longer changes which sub-block is shown: Android leads by default.
    const detected = isAndroid()
      ? 'android'
      : isIOSSafariPWA()
        ? 'ios'
        : 'desktop';

    root.dataset.detected = detected;

    const toggle = root.querySelector<HTMLElement>('.install__toggle');
    toggle?.removeAttribute('hidden');

    const btn = root.querySelector<HTMLButtonElement>('[data-show-all]');
    btn?.addEventListener('click', () => {
      root.classList.add('show-all');
      toggle?.setAttribute('hidden', '');
    });
  }
</script>

<style>
  .install {
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(3, 1fr);
    background: var(--hairline-soft);
    border: 1px solid var(--hairline-soft);
    border-radius: 6px;
    overflow: hidden;
  }
  .how-card {
    background: var(--bg-elev-1);
    padding: clamp(24px, 3vw, 32px);
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .plat {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--fg-mute);
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .plat .badge {
    background: var(--bg-elev-2);
    color: var(--fg);
    padding: 3px 9px;
    border-radius: 3px;
    font-size: 11px;
    border: 1px solid var(--hairline);
  }
  .how-card h3 {
    font-family: var(--font-display);
    font-size: 22px;
    margin: 0 0 14px;
    color: var(--fg);
  }
  .how-card p {
    margin: 0 0 12px;
    color: var(--fg-mute);
    font-size: 14.5px;
    line-height: 1.6;
  }
  .how-card a {
    color: var(--accent-hi);
  }
  .install__badge {
    margin: 6px 0 16px;
  }
  .qr-label {
    font-size: 13px;
    color: var(--fg-dim);
  }
  .note {
    font-size: 13.5px;
    color: var(--fg-dim);
  }
  .warn {
    font-size: 13px;
    color: var(--warning);
    border-left: 2px solid var(--warning);
    padding-left: 0.75rem;
    margin-top: 6px;
    margin-bottom: 0;
  }
  .install__toggle {
    grid-column: 1 / -1;
    background: var(--bg);
    padding: 14px;
  }
  .install__toggle button {
    background: transparent;
    border: 1px solid var(--hairline);
    color: var(--fg-mute);
    border-radius: 8px;
    padding: 0.45rem 0.9rem;
    font: inherit;
    font-size: 0.875rem;
    cursor: pointer;
  }
  .install__toggle button:hover {
    border-color: var(--accent);
    color: var(--fg);
  }

  @media (max-width: 860px) {
    .install {
      grid-template-columns: 1fr;
    }
  }

  /* Android always leads — it's the primary distribution channel (full, paid
     app). Only the Android block shows until the visitor clicks "Show all
     platforms"; detected platform never changes this. */
  .install:not(.show-all) .how-card {
    display: none;
  }
  .install:not(.show-all) .how-card[data-platform='android'] {
    display: flex;
  }
</style>
