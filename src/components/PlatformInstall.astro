---
/**
 * The three install sub-blocks (Android / Desktop / iOS).
 *
 * V1 is a pure PWA, distributed from app.qualireps.app on every platform. All three
 * blocks render server-side and are always shown, in order: Android, Desktop,
 * iOS. A small bundled client script records the detected platform (kept for
 * analytics / future logic); it does not hide or reorder any block.
 *
 * The Google Play TWA channel is postponed to a conditional V1.5: the Play
 * badge + QR markup is preserved but gated behind PLAY_TWA_ENABLED (see
 * lib/config.ts). PlayBadge / QRCode / PLAY_STORE_URL stay imported so flipping
 * that one flag is all the V1.5 chantier needs.
 */
import PlayBadge from './PlayBadge.astro';
import QRCode from './QRCode.astro';
import { PLAY_STORE_URL } from '../lib/playBilling';
import { PLAY_TWA_ENABLED } from '../lib/config';
import { APP_URL, APP_HOST } from '../lib/site';
---

<div class="install" data-platform-install>
  <!-- Android -->
  <section class="how-card" data-platform="android" aria-label="Android">
    <div class="plat"><span class="badge">Android</span><span>Chrome · install from browser</span></div>
    <h3>Android</h3>
    <ol class="steps">
      <li>Open {APP_HOST} in Chrome.</li>
      <li>Tap the menu (⋮), then "Install app" (or "Add to Home Screen").</li>
      <li>It installs like a native app and runs fully offline.</li>
    </ol>
    {
      PLAY_TWA_ENABLED && (
        <>
          <div class="install__badge">
            <PlayBadge />
          </div>
          <p class="qr-label">Scan with your phone:</p>
          <QRCode value={PLAY_STORE_URL} alt="QR code linking to QualiReps on Google Play" />
        </>
      )
    }
    <a href={APP_URL} class="btn btn-ghost open-btn">Open {APP_HOST}</a>
  </section>

  <!-- Desktop -->
  <section class="how-card" data-platform="desktop" aria-label="Desktop">
    <div class="plat"><span class="badge">Desktop</span><span>Chrome · Edge</span></div>
    <h3>Desktop</h3>
    <ol class="steps">
      <li>Open {APP_HOST} in Chrome or Edge.</li>
      <li>Click the install icon in the address bar.</li>
      <li>It runs offline as a standalone app.</li>
    </ol>
    <a href={APP_URL} class="btn btn-ghost open-btn">Open {APP_HOST}</a>
  </section>

  <!-- iOS -->
  <section class="how-card" data-platform="ios" aria-label="iOS">
    <div class="plat"><span class="badge">iOS</span><span>Safari</span></div>
    <h3>iOS</h3>
    <ol class="steps">
      <li>Open {APP_HOST} in Safari.</li>
      <li>Tap the Share icon.</li>
      <li>Tap "Add to Home Screen".</li>
    </ol>
    <p class="note">
      Once on your home screen, the app and its data live on your device. As
      with any local-only data, regular backups remain recommended.
    </p>
    <a href={APP_URL} class="btn btn-ghost open-btn">Open {APP_HOST}</a>
  </section>
</div>

<script>
  import { isAndroid, isIOSSafariPWA } from '../lib/platform';

  const root = document.querySelector<HTMLElement>('[data-platform-install]');
  if (root) {
    // Best-effort platform detection. Recorded on data-detected for
    // analytics / future logic, and used below as progressive enhancement
    // to emphasize the matching card. The SSR output stays unchanged: with
    // no JS, all three cards render equal (ghost buttons, no highlight).
    const detected = isAndroid()
      ? 'android'
      : isIOSSafariPWA()
        ? 'ios'
        : 'desktop';

    root.dataset.detected = detected;

    // Emphasize only the matching card — never reorder or hide any card.
    // If the card can't be found, every card stays in the default state.
    const match = root.querySelector<HTMLElement>(
      `.how-card[data-platform="${detected}"]`
    );
    if (match) {
      match.classList.add('is-detected');
      const btn = match.querySelector('.open-btn');
      if (btn) {
        btn.classList.remove('btn-ghost');
        btn.classList.add('btn-primary');
      }
    }
  }
</script>

<style>
  .install {
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(3, 1fr);
    background: var(--hairline-soft);
    border: 1px solid var(--hairline-soft);
    border-radius: 6px;
    overflow: hidden;
  }
  .how-card {
    background: var(--bg-elev-1);
    padding: clamp(24px, 3vw, 32px);
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  /* Progressive enhancement: the JS-detected platform's card gets a
     restrained accent cue. Inset box-shadow avoids any layout shift, so
     the no-JS / undetected fallback (all cards equal) stays pixel-identical. */
  .how-card.is-detected {
    background: var(--bg-elev-2);
    box-shadow: inset 0 0 0 1px var(--accent);
  }
  .plat {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--fg-mute);
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .plat .badge {
    background: var(--bg-elev-2);
    color: var(--fg);
    padding: 3px 9px;
    border-radius: 3px;
    font-size: 11px;
    border: 1px solid var(--hairline);
  }
  .how-card h3 {
    font-family: var(--font-display);
    font-size: 22px;
    margin: 0 0 14px;
    color: var(--fg);
  }
  .how-card p {
    margin: 0 0 12px;
    color: var(--fg-mute);
    font-size: 14.5px;
    line-height: 1.6;
  }
  .steps {
    margin: 0 0 20px;
    padding-left: 1.4em;
    color: var(--fg-mute);
    font-size: 14.5px;
    line-height: 1.6;
  }
  .steps li {
    margin: 0 0 8px;
    padding-left: 4px;
  }
  .steps li:last-child {
    margin-bottom: 0;
  }
  .steps li::marker {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 12px;
  }
  /* Push the action button to the card's lower edge so all three align. */
  .open-btn {
    margin-top: auto;
    align-self: flex-start;
    height: 46px;
    padding: 0 20px;
    font-size: 14px;
  }
  .install__badge {
    margin: 6px 0 16px;
  }
  .qr-label {
    font-size: 13px;
    color: var(--fg-dim);
  }
  .note {
    font-size: 13.5px;
    color: var(--fg-dim);
    margin-top: 6px;
    margin-bottom: 0;
  }
  @media (max-width: 860px) {
    .install {
      grid-template-columns: 1fr;
    }
  }
</style>
