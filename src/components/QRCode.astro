---
/**
 * Build-time QR code. Renders an inline SVG generated by the `qrcode` package
 * during the static build — no runtime JS, no network request, no CDN.
 */
import QRCodeLib from 'qrcode';

interface Props {
  /** The URL/text to encode. */
  value: string;
  /** Pixel size of the rendered SVG (CSS). */
  size?: number;
  alt?: string;
}
const { value, size = 160, alt = 'QR code' } = Astro.props;

// Charbon background, sand foreground to match the brand.
const svg: string = await QRCodeLib.toString(value, {
  type: 'svg',
  margin: 1,
  errorCorrectionLevel: 'M',
  color: {
    dark: '#e8e4de',
    light: '#1c1a18',
  },
});
---

<div
  class="qrcode"
  style={`width:${size}px;height:${size}px`}
  role="img"
  aria-label={alt}
  set:html={svg}
>
</div>

<style>
  .qrcode {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--color-border-default);
    background: var(--color-charbon);
    padding: 8px;
    box-sizing: content-box;
  }
  .qrcode :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
