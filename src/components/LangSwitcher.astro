---
/**
 * EN / FR language pill (matches the original landing).
 * V1: English only. FR points at /fr, which redirects to / (see astro.config).
 * The element is present so the FR funnel exists the moment FR content lands.
 */
---

<div class="lang" role="group" aria-label="Language">
  <span class="active" aria-current="true">EN</span>
  <a href="/fr" hreflang="fr" lang="fr">FR</a>
</div>

<style>
  .lang {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    padding: 2px;
  }
  .lang > * {
    color: var(--fg-mute);
    padding: 5px 12px;
    border-radius: 999px;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .lang > a:hover {
    color: var(--fg);
  }
  .lang .active {
    background: var(--bg-elev-2);
    color: var(--fg);
  }
</style>
