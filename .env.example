# QualiReps — server environment.
# Copy to .env for local development; set the same keys in the Vercel project.
# Never commit a filled-in .env (it is gitignored).

# Paddle API key (server-side, secret). Used for GET /transactions and
# GET /customers. From Paddle dashboard → Developer tools → Authentication.
PADDLE_API_KEY=

# Paddle webhook signing secret (per notification destination, prefixed
# `pdl_ntfset_`). Verifies the Paddle-Signature header.
PADDLE_WEBHOOK_SECRET=

# Paddle client-side token (publishable). Initializes Paddle.js on /buy.
PADDLE_CLIENT_TOKEN=

# Paddle price id for the lifetime license (`pri_...`).
PADDLE_PRICE_ID=

# Which Paddle environment to talk to: `sandbox` or `production`.
PADDLE_ENV=sandbox

# License signing key — Ed25519 private key, PKCS8 DER base64.
# Generate with: node scripts/generate-keypair.mjs
LICENSE_SIGNING_KEY=

# Resend API key (secret). Sends the license-key email.
RESEND_API_KEY=
